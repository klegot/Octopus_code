{
    "configurations": [
        {
            "name": "AVR",
            "includePath": [
                "${workspaceFolder}/**",
                "/opt/avr-gcc/avr/include/**"
            ],
            "defines": [
                "__AVR_ATtiny414__",
                "__AVR_XMEGA__"
            ],
            "compilerPath": "/opt/avr-gcc/bin/avr-gcc",
            "compilerArgs": [
                "-mmcu=attiny414"
            ],
            "cStandard": "gnu17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}
